@page "/api-exports"
@using System.IO
@using HomeHeatMap.Services
@inject IApiExportService ExportService
@inject ILogger<ApiExports> Logger

<PageTitle>API Exports</PageTitle>

<h1>📊 API Response Exports</h1>

<p>All API responses are automatically exported to CSV and JSON formats for inspection.</p>

<div class="alert alert-info">
    <strong>📁 Export Folder:</strong> <code>@ExportService.GetExportDirectory()</code>
</div>

<div style="margin-bottom: 20px;">
    <a href="/" class="btn btn-secondary">← Back to Home</a>
    <button class="btn btn-warning" @onclick="RefreshFiles">🔄 Refresh Files</button>
</div>

@if (files == null)
{
    <p><em>Loading files...</em></p>
}
else if (files.Count == 0)
{
    <p style="color: #666;"><em>No exports yet. Run the heat map to generate data.</em></p>
}
else
{
    <div style="margin-bottom: 10px; padding: 10px; background: #e7f3ff; border-radius: 5px;">
        <strong>📈 Found @files.Count files</strong>
    </div>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Filename</th>
                <th>Type</th>
                <th>Size</th>
                <th>Created</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var file in files.OrderByDescending(f => f.CreationTime))
            {
                var isJson = file.Extension == ".json";
                var isCsv = file.Extension == ".csv";
                <tr>
                    <td>
                        <code style="font-size: 0.9em;">@file.Name</code>
                    </td>
                    <td>
                        @if (isJson)
                        {
                            <span class="badge bg-info">JSON</span>
                        }
                        else if (isCsv)
                        {
                            <span class="badge bg-success">CSV</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@file.Extension</span>
                        }
                    </td>
                    <td>@FormatFileSize(file.Length)</td>
                    <td style="font-size: 0.9em;">@file.CreationTime.ToString("MM/dd HH:mm:ss")</td>
                    <td>
                        <a href="/exports/@file.Name" download class="btn btn-sm btn-primary">📥 Download</a>
                        @if (isCsv || isJson)
                        {
                            <button class="btn btn-sm btn-secondary" @onclick="() => PreviewFile(file)">👁️ Preview</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (!string.IsNullOrEmpty(previewContent))
{
    <hr />
    <h3>📄 Preview: @previewFilename</h3>
    <button class="btn btn-sm btn-secondary" @onclick="() => { previewContent = null; }">Close Preview</button>
    <pre style="max-height: 500px; overflow: auto; background: #f5f5f5; padding: 15px; border-radius: 5px; margin-top: 10px;">@previewContent</pre>
}

@code {
    private List<FileInfo>? files;
    private string? previewContent;
    private string? previewFilename;

    protected override async Task OnInitializedAsync()
    {
        await LoadFiles();
    }

    private Task LoadFiles()
    {
        try
        {
            var exportDir = ExportService.GetExportDirectory();
            var dirInfo = new DirectoryInfo(exportDir);
            files = dirInfo.GetFiles().ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading files");
            files = new List<FileInfo>();
        }
        return Task.CompletedTask;
    }

    private Task RefreshFiles()
    {
        LoadFiles();
        previewContent = null;
        return Task.CompletedTask;
    }

    private async Task PreviewFile(FileInfo file)
    {
        try
        {
            previewContent = await File.ReadAllTextAsync(file.FullName);
            previewFilename = file.Name;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error reading file");
            previewContent = $"Error: {ex.Message}";
        }
    }

    private string FormatFileSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }
}